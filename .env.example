# iamnotai 프록시 환경변수 (Vercel > Settings > Environment Variables 에 등록)
# 로컬에서 `vercel dev` 로 테스트할 때는 이 파일을 .env.local 로 복사해 채워넣으세요.

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Upstage (Solar-Open2-Preview)
UPSTAGE_API_KEY=
UPSTAGE_MODEL=solar-open2-preview

# 선택: 허용 오리진 (공개 시 자기 도메인으로 제한 권장, 기본 *)
ALLOWED_ORIGIN=*
