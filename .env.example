# iamnotai 환경변수 (Vercel > Settings > Environment Variables)
# 로컬 테스트(`vercel dev`)는 이 파일을 .env.local 로 복사해 채우세요.

# ── ✨ LLM 윤문 ──
# Gemini: 서버(운영자) 키로 처리 — 모든 사용자 공용 (과금=운영자)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Upstage(Solar)는 서버 키를 두지 않습니다. 사용자가 웹앱 ⚙️설정에서 본인 키 입력
# → 프록시가 통과시켜 호출(저장 안 함, 과금=사용자).

# ── 🤖 AI 분석 / 감사 검증 (Claude) ──
# 설정하면 운영자 키로 공용 제공(과금=운영자).
# 비워두면 사용자가 ⚙️설정에서 본인 Anthropic 키 입력(BYO, 과금=사용자)으로 폴백.
ANTHROPIC_API_KEY=

# 선택: 허용 오리진 (공개 시 자기 도메인으로 제한 권장, 기본 *)
ALLOWED_ORIGIN=*
