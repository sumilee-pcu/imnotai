# iamnotai 프록시 환경변수 (Vercel > Settings > Environment Variables 에 등록)
# 로컬에서 `vercel dev` 로 테스트할 때는 이 파일을 .env.local 로 복사해 채워넣으세요.

# Google Gemini — 서버(운영자) 키로 처리 (모든 사용자 공용, 과금=운영자)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Upstage(Solar)는 서버 키를 두지 않습니다.
# 사용자가 웹앱에서 본인 Upstage 키를 입력 → 프록시가 통과시켜 호출(저장 안 함, 과금=사용자).

# 선택: 허용 오리진 (공개 시 자기 도메인으로 제한 권장, 기본 *)
ALLOWED_ORIGIN=*
